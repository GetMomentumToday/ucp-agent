# AI Provider — set one or both. AI_PROVIDER selects which to use.
# Options: "gemini" (default) or "claude"
AI_PROVIDER=gemini

# Gemini (free tier: 10 RPM, 250 RPD)
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key

# Claude (pay per token — Sonnet 4.5 by default)
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model ID
# AI_MODEL=gemini-2.5-flash

# UCP
GATEWAY_URL=http://localhost:3000
UCP_AGENT_PROFILE=http://localhost:3001/agent-profile.json
